# Dependencies — reinstalled fresh inside the image
node_modules

# Next.js build output — regenerated inside the image
.next
out

# SQLite database — this is local dev state, not something to bake into
# the image. The container creates/seeds its own at runtime via a volume.
app/data/*.db
app/data/*.db-shm
app/data/*.db-wal

# Env files — pass real values via compose.yaml / --env-file instead
.env
.env*.local

# Editor/OS noise
.git
.gitignore
.DS_Store
*.pem
certificates

# Misc
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
README.md
*.md
.vscode
.idea
coverage
*.tsbuildinfo
next-env.d.ts
EOF